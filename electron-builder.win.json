{
  "appId": "edu.ucsd.tritonai.installer",
  "productName": "TritonAI Installer",
  "asar": false,
  "compression": "normal",
  "directories": {
    "output": "artifacts/windows-installer"
  },
  "files": [
    "package.json",
    "README.md",
    "dist/src/**/*",
    "docs/**/*",
    "vendor/skills/**/*",
    "vendor/codex-cli/win-x64/**/*",
    "vendor/t3code-desktop/win-x64/**/*"
  ],
  "extraResources": [
    {
      "from": "build/managed-config.generated.json",
      "to": "managed-config.json"
    },
    {
      "from": "build/managed-plugin-composition.generated.json",
      "to": "managed-plugin-composition.json"
    }
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "TritonAI-Installer-Setup-${version}-${arch}.${ext}"
  },
  "portable": {
    "artifactName": "TritonAI-Installer-${version}-${arch}-portable.${ext}"
  },
  "nsis": {
    "include": "build/installer.nsh",
    "oneClick": false,
    "perMachine": false,
    "allowElevation": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "TritonAI Installer"
  },
  "publish": null
}
